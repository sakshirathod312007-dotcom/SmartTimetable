<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SmartTimetable" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary Brand Colors -->
        <item name="colorPrimary">#5F5BFF</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="colorSecondary">#8E24AA</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Background -->
        <item name="android:colorBackground">#F5F6FA</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">#5F5BFF</item>

    </style>
    <style name="AppButtonStyle" parent="Widget.Material3.Button">
        <item name="backgroundTint">#5F5BFF</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="DashboardButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginEnd">20dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">#2C2C8C</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

</resources>
